{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "rootDir": "src",
        "outDir": "dist",
        "sourceMap": true,
        "rewriteRelativeImportExtensions": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["coverage", "dist", "node_modules", "src/**/*.test.ts"]
}
